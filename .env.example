# Copy this file to .env and fill in your own values.
# .env is gitignored so your settings stay local.

# Path to the SQLite database file.
AKASHIC_DB_PATH=data/akashic.db

# Name of the embedding model used for semantic search.
# IMPORTANT: keep this fixed once you start storing data. All vectors in the
# database must come from the SAME model, or similarity search is meaningless.
AKASHIC_EMBEDDING_MODEL=all-MiniLM-L6-v2
